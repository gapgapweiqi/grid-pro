# API URL — Cloudflare Worker (public, no secret)
VITE_API_URL=https://api.grid-doc.com

# Web App Origin — used for OAuth redirect URIs (must match Google Console)
VITE_APP_ORIGIN=https://app.grid-doc.com

# Marketing Site URL — used for cross-domain links (header, footer, redirects)
VITE_MARKETING_URL=https://grid-doc.com

# Google OAuth Client ID (public, no secret — only the Client ID, NOT the secret)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
